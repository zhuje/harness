{
  "permissions": {
    "additionalDirectories": [
      "./projects/console",
      "./projects/konflux-coo",
      "./projects/logging-view-plugin",
      "./projects/monitoring-plugin",
      "./projects/observability-operator",
      "./projects/perses",
      "./projects/operator",
      "./projects/perses-plugins",
      "./projects/perses-shared",
      "./projects/perses-spec"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint:fix",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
